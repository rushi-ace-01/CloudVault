# ============================================
# CloudVault Server Configuration
# Copy this file as .env and update values
# ============================================

# Server
PORT=5000
NODE_ENV=development

# MySQL Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=cloudvault

# JWT Secret (change this to a random string)
JWT_SECRET=cloudvault_super_secret_key_change_me_2025

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=52428800

# Frontend URL (set this to your Vercel URL in production)
CLIENT_URL=http://localhost:5173
